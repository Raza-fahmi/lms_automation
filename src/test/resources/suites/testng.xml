<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Test Suite">
    <listeners>
        <listener class-name="core.listener.TestListener"/>
    </listeners>

    <!-- UI Tests -->
    <test name="UI Tests">
        <classes>
            <class name="ui.lms.LoginTest"/>
            <class name="ui.lms.EmployeeTest"/>
        </classes>
    </test>

    <!-- API Tests -->
    <test name="API Tests">
        <classes>
            <class name="api.tests.LoginApiTest"/>
            <class name="api.tests.EmployeeApiTest"/>
        </classes>
    </test>
</suite>